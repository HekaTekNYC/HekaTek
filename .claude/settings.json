{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit:*)",
            "command": "npm run test:unit && npm run test:integration && npm run lint && npm run typecheck",
            "timeout": 120,
            "statusMessage": "Running pre-commit checks (tests, lint, typecheck)..."
          }
        ]
      }
    ]
  }
}
